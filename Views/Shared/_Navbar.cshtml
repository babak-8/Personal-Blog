<header class="site-header">
    <nav class="navbar navbar-expand-lg fixed-top navbar-clean">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" asp-controller="Post" asp-action="Index">
                Babak
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navRes">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navRes">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link active" asp-action="Index" asp-controller="Post">@localizer["anasayfa"]</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Hakkimda" asp-controller="Post">@localizer["hakkimda"]</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Mail" asp-action="Index">@localizer["iletisim"]</a></li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <div class="navbar-auth d-flex gap-2 align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-light rounded-pill btn-medium">@localizer["cikisYap"]</a>
                        }
                        else
                        {
                            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-light rounded-pill btn-medium">@localizer["girisYap"]</a>
                            <a asp-controller="Auth" asp-action="Register" class="btn btn-light rounded-pill fw-bold btn-medium">@localizer["kayitOl"]</a>
                        }
                    </div>

                    <div class="dropdown">
                        <a class="btn btn-light dropdown-toggle rounded-pill btn-medium text-primary fw-bold" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-globe me-1"></i> @System.Globalization.CultureInfo.CurrentUICulture.NativeName
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li><a class="dropdown-item fw-medium" asp-route-culture="tr" asp-controller="Language" asp-action="Index">Türkçe</a></li>
                            <li><a class="dropdown-item fw-medium" asp-route-culture="en" asp-controller="Language" asp-action="Index">English</a></li>
                            <li><a class="dropdown-item fw-medium" asp-route-culture="ru" asp-controller="Language" asp-action="Index">Русский</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>
</header>

<style>
    /* --- Genel Navbar Ayarları --- */
    .navbar-clean {
        background-color: royalblue;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding: 12px 0;
        transition: all 0.3s ease;
    }
    

    .navbar-brand {
        font-size: 1.4rem;
        letter-spacing: 1px;
    }

    .navbar-clean .nav-link {
        color: rgba(255, 255, 255, 0.8) !important;
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

        .navbar-clean .nav-link:hover,
        .navbar-clean .nav-link.active {
            color: #ffffff !important;
        }

    /* --- Hamburger (Toggle) Butonu Ayarları --- */
    .navbar-toggler {
        border: none !important;
        box-shadow: none !important;
        outline: none !important;
        filter: brightness(0) invert(1); /* İkonu beyaz yapmak için yedek */
    }

    .navbar-toggler-icon {
        /* Özel Beyaz SVG İkon */
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255, 255, 255, 1)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    }

    /* --- Buton Stilleri --- */
    .btn-login {
        text-decoration: none;
        font-weight: 500;
        padding: 5px 10px;
        transition: opacity 0.2s;
        color: white;
    }

        .btn-login:hover {
            opacity: 0.8;
            color: #ddd;
        }

    .btn-light {
        color: royalblue !important;
        border: none;
    }

 
    media (max-width: 980px) {
        .navbar-clean{
        padding-left: 15px;
        padding-bottom:205px;
    }
        .navbar-collapse{
        background: royalblue;
        
        margin-top: 10px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        padding: 30px 20px 40px 20px;
    }

    .navbar-nav {
        text-align: left;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 15px;
        padding-bottom: 15px;
    }

    /* Mobilde öğelerin alt alta gelmesi */
    .navbar-collapse .d-flex {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 15px !important;
    }

    .navbar-auth {
        margin-top: 15px;
        width: 100%;
        display: flex;
        justify-content: space-between;
        flex-direction: row !important; 
    }
    }
</style>