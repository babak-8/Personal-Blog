<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        #menu-toggle {
            display: none;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .sidebar-admin {
            width: 280px;
            background-color: #212529;
            min-height: 100vh;
            position: fixed;
            left: 0;
            transition: transform 0.3s ease;
            z-index: 1000;
        }

        .main-content {
            flex: 1;
            margin-left: 280px;
            background-color: #f8f9fa;
            transition: margin 0.3s ease;
        }

        .nav-pills .nav-link {
            color: rgba(255,255,255,0.8);
            border-radius: 10px;
            margin-bottom: 5px;
        }

        .nav-pills .nav-link:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-pills .nav-link.active {
            background: white !important;
            color: #0d6efd !important;
            font-weight: bold;
        }

        @@media (max-width: 970px) {
            .sidebar-admin {
                transform: translateX(-100%);
                width:220px;
            }

            .main-content {
                margin-left: 0;
            }

            #menu-toggle:checked ~ .admin-wrapper .sidebar-admin {
                transform: translateX(0);
            }

            .hamburger-label {
                display: flex !important;
                cursor: pointer;
                padding: 10px;
                background: #fff;
                color: white;
                border-radius: 5px;
                margin-right: 15px;
            }

            .container-fluid{
                margin-top:23px;
            }
        }

        .hamburger-label {
            display: none;
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 99999;
        
        }

    </style>
</head>
<body>

    <input type="checkbox" id="menu-toggle">

    <div class="admin-wrapper">
        <div class="sidebar-admin d-flex flex-column flex-shrink-0 p-3 text-white shadow">
            <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <span class="fs-4 fw-bold">Babak<span class="opacity-75">Panel</span></span>
            </a>
            <hr>
            <ul class="nav nav-pills flex-column mb-auto">
                <li>
                    <a asp-controller="Post" asp-action="Index" class="nav-link text-white">
                        <i class="fas fa-list-ul me-2"></i>Postları Yönet
                    </a>
                </li>

                <li>
                    <a asp-controller="Post" asp-action="YorumlarYonetimi" class="nav-link text-white">
                        <i class="fas fa-comments me-2"></i>Yorumları Yönet
                    </a>
                </li>

                <li>
                    <a asp-controller="Post" asp-action="Kategoriler" class="nav-link text-white">
                        <i class="fas fa-folder me-2"></i>Kategorileri Yönet
                    </a>
                </li>
            </ul>
            <div class="p-1 mt-auto">
                <a asp-controller="Auth" asp-action="Logout"
                   class="btn btn-danger w-100 d-flex align-items-center justify-content-center fw-bold shadow-sm"
                   style="background-color: #dc3545; color: white; border: none;text-align:center; padding: 10px; border-radius: 8px;">
                    <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                </a>
            </div>
        </div>

        <div class="main-content">
            <label for="menu-toggle" class="hamburger-label m-0 p-2">
                <i class="fas fa-bars fs-3 text-dark"></i>
            </label>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const sidebar = document.getElementsByClassName('sidebar-admin');
        const govde = document.body;

        govde.addEventListener('click', () => {
            sidebar.style.display = 'none';
        });
    </script>
</body>
</html>