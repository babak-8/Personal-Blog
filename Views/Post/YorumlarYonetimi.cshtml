@model IEnumerable<BabakBlog.Models.Yorum>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yorum Yönetimi";
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive mt-4 shadow-sm rounded border bg-white">
        <table class="table table-hover align-middle mb-0 custom-admin-table">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="ps-3">Kullanıcı</th>
                    <th>Yorum İçeriği</th>
                    <th>İlgili Yazı</th>
                    <th>Tarih</th>
                    <th class="text-end pe-4">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-2 text-wrap">
                            <div class="fw-bold text-dark">
                                <i class="fas fa-user-circle me-1 text-secondary"></i> @item.kullaniciAdi
                            </div>
                        </td>

                        <td class="text-wrap" style="max-width: 300px;">
                            @item.icerik
                        </td>

                        <td class="text-wrap" style="max-width: 200px;">
                            <span class="badge bg-light text-dark border fw-normal">
                                @(item.Post?.baslik ?? "Silinmiş Yazı")
                            </span>
                        </td>

                        <td class="text-wrap">
                            <div class="small">
                                <div class="fw-bold text-dark">@item.yorumTarih.ToString("dd.MM.yyyy")</div>
                                <div class="text-muted" style="font-size: 0.75rem;">
                                    @item.yorumTarih.ToString("HH:mm")
                                </div>
                            </div>
                        </td>

                        <td class="text-end pe-3">
                            <a asp-action="YorumSil" asp-controller="Post" asp-route-id="@item.id" class="text-danger p-2 bg-transparent border-0">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5 mt-4 border rounded-3 bg-light">
        <i class="fas fa-comment-slash fa-3x text-muted mb-3"></i>
        <h5 class="text-secondary">Henüz hiç yorum yapılmamış.</h5>
        <p class="text-muted small">Blog yazılarına yorum geldiğinde burada listelenecektir.</p>
    </div>
}


