<section class="py-5 mt-5">
    <div class="container">
        <div class="row mb-5">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="display-4 fw-bold mb-3">@ViewData["Title"]</h2>
                <p class="lead text-muted">@localizer["hakkimParagraf1"]</p>
                <div class="bg-primary mx-auto" style="height: 3px; width: 60px;"></div>
            </div>
        </div>

        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <div class="position-relative mb-4 mb-lg-0">
                    <img src="~/images/586ef26a-f5a2-40ac-afb8-84a4d76933e1.jpeg" alt="Babak" class="img-fluid rounded-4 shadow-lg border">
                    <div class="position-absolute bottom-0 start-0 bg-primary text-white p-3 rounded-tr-4 m-2 shadow">
                        <span class="fw-bold">@localizer["yas"]</span> @localizer["alan"]
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <h3 class="fw-bold mb-4">@localizer["ben"] Babak</h3>
                <p class="text-secondary mb-4">
                    @localizer["hakkimParag2"] <strong>@localizer["universite"]</strong>@localizer["hakkimParag2"]
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light hover-shadow transition">
                            <h6 class="fw-bold mb-2"><i class="fas fa-code text-primary me-2"></i>@localizer["backend"]</h6>
                            <small class="text-muted">ASP.NET Core MVC, C#, SQL Server, MySQL</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light hover-shadow transition">
                            <h6 class="fw-bold mb-2"><i class="fas fa-layer-group text-primary me-2"></i>@localizer["frontend"]</h6>
                            <small class="text-muted">React, JavaScript, HTML5, CSS3, Bootstrap</small>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-3">@localizer["kodOtesi"]</h5>
                <p class="text-secondary mb-5">
                    @localizer["hakkimParag4"] <strong>@localizer["spor"]</strong> @localizer["hakkimParag5"] <strong>@localizer["enstruman"]</strong> @localizer["hakkimParag6"]

                <div class="mt-5 pt-4 border-top">
                    <div class="row align-items-center g-4">
                        <div class="col-md-3 text-center">
                            <div class="bg-black d-inline-block shadow overflow-hidden" style="width: 110px; height: 110px; border-radius: 50%; border: 2px solid #333;">
                                <img src="~/images/48d4ec48-7e56-45ae-8ae8-1edacbfc88da.jpeg"
                                     alt="Babirapson Markası"
                                     class="img-fluid"
                                     style="object-fit: contain; width: 100%; height: 100%; transform: scale(0.9);">
                            </div>
                        </div>

                        <div class="col-md-9 text-center text-md-start">
                            <h4 class="fw-bold text-dark mb-2">Babirapson @localizer["vizyon"]</h4>
                            <p class="text-secondary mb-0" style="font-size: 0.95rem; line-height: 1.6;">
                                @localizer["hakkimParag8"]
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-4 g-4 text-center">
            <div class="col-md-4">
                <i class="fas fa-graduation-cap fa-2x text-primary mb-3 transition-icon"></i>
                <h5 class="fw-bold">@localizer["egitim"]</h5>
                <p class="text-muted">@localizer["bolum"]</p>
            </div>
            <div class="col-md-4">
                <i class="fas fa-globe-americas fa-2x text-primary mb-3 transition-icon"></i>
                <h5 class="fw-bold">@localizer["dil"]</h5>
                <p class="text-muted">@localizer["diller"]</p>
            </div>
            <div class="col-md-4">
                <i class="fas fa-plane-departure fa-2x text-primary mb-3 transition-icon"></i>
                <h5 class="fw-bold">@localizer["hedef"]</h5>
                <p class="text-muted">@localizer["polonya"]</p>
            </div>
        </div>
    </div>
</section>

<style>
    .transition { transition: all 0.3s ease-in-out; }
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .transition-icon { transition: transform 0.2s ease; }
    .col-md-4:hover .transition-icon { transform: scale(1.15); }
    .rounded-tr-4 { border-top-right-radius: 1.5rem; }
    .border-secondary { border-color: #6c757d!important; }
</style>