<div class="d-flex justify-content-between align-items-center mt-4">
    <a asp-action="KategoriEkle" asp-controller="Post" class="btn btn-primary mt-1">
        <i class="fas fa-plus me-1"></i> Kategori Ekle
    </a>
</div>
@model IEnumerable<BabakBlog.Models.Kategori>

<div class="table-responsive mt-4 shadow-sm rounded border bg-white">
    <table class="table table-hover align-middle mb-0 custom-admin-table" style="min-width: 600px;">
        <thead class="bg-dark text-white">
            <tr>
              
                <th scope="col">Kategori Adı (TR)</th>
                <th scope="col">İngilizce (EN)</th>
                <th scope="col">Rusça (RU)</th>
                <th scope="col" class="text-end pe-4">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold text-dark ps-2">
                            @item.isim
                        </div>
                    </td>
                    <td>
                        <span class="text-muted">@(item.isim_EN ?? "-")</span>
                    </td>
                    <td>
                        <span class="text-muted">@(item.isim_RU ?? "-")</span>
                    </td>
                    <td class="text-end pe-3">
                        <div class="d-flex justify-content-end">
                            <a asp-action="KategoriEdit" asp-controller="Post" asp-route-id="@item.id" class="text-primary p-2 hover-bg-light rounded" title="Düzenle">
                                <i class="fas fa-pen"></i>
                            </a>
                            <a asp-action="KategoriSil" asp-controller="Post" asp-route-id="@item.id" class="text-danger p-2 hover-bg-light rounded" title="Sil">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>