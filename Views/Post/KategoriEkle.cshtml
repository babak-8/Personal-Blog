@model BabakBlog.Models.Kategori
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif
    }

    .form-group {
        padding-bottom: 12px;
    }
</style>

<div class="content-wrapper">
    <div class="row">
        <div class="col-6">
            <h2>@ViewData["Title"]</h2>
        </div>
    </div>

    <hr />

    <form asp-action="KategoriEkle" asp-controller="Post" method="post">
        <div class="form-group">
            <label asp-for="isim">Kategori Adı</label>
            <input asp-for="isim" class="form-control" />
            <span asp-validation-for="isim" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Kategori Adı (EN)</label>
            <input asp-for="isim_EN" class="form-control"/>
        </div>

        <div class="form-group">
            <label>Kategori Adı (RU)</label>
            <input asp-for="isim_RU" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary mt-1">Kaydet</button>
        <a asp-action="Kategoriler" asp-controller="Post" class="btn btn-danger mt-1">İptal</a>
    </form>
</div>